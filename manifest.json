<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0,viewport-fit=cover"/>
  <meta name="theme-color" content="#07070f"/>
  <meta name="apple-mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
  <meta name="apple-mobile-web-app-title" content="PokéScan"/>
  <link rel="manifest" href="manifest.json"/>
  <link rel="apple-touch-icon" href="icons/icon-192.png"/>
  <title>PokéScan</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style>
  :root{
    --bg:#07070f;--bg2:#0e0e1c;--bg3:#15152a;--surf:#1a1a2e;
    --brd:rgba(255,255,255,.08);--brd2:rgba(255,255,255,.14);
    --a:#f5c518;--ag:rgba(245,197,24,.2);
    --red:#ff3b5c;--green:#00e676;--text:#eeeef5;--text2:#9999b3;--text3:#55556a;
    --r:14px;--r2:10px;
    --font:'Syne',sans-serif;--body:'DM Sans',sans-serif;
    --st:env(safe-area-inset-top,0px);--sb:env(safe-area-inset-bottom,0px);
  }
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
  html,body{height:100%;background:var(--bg);color:var(--text);font-family:var(--body);overflow:hidden}
  #app{display:flex;flex-direction:column;height:100vh;height:100dvh}
  #app::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
    background:radial-gradient(ellipse 70% 50% at 10% 0%,rgba(79,142,255,.09) 0%,transparent 60%),
               radial-gradient(ellipse 60% 60% at 90% 100%,rgba(176,96,255,.07) 0%,transparent 60%)}

  header{position:relative;z-index:10;padding:calc(var(--st) + 14px) 16px 14px;
    display:flex;align-items:center;gap:12px;
    background:rgba(7,7,15,.92);backdrop-filter:blur(24px);border-bottom:1px solid var(--brd)}
  .ball{width:34px;height:34px;border-radius:50%;flex-shrink:0;position:relative;overflow:hidden;
    border:2px solid rgba(255,255,255,.12);box-shadow:0 0 14px var(--ag)}
  .ball-t{position:absolute;top:0;left:0;right:0;height:50%;background:var(--red)}
  .ball-b{position:absolute;bottom:0;left:0;right:0;height:50%;background:#ddd}
  .ball::after{content:'';position:absolute;left:0;right:0;top:50%;transform:translateY(-50%);height:2px;background:#111;z-index:1}
  .ball-c{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:9px;height:9px;border-radius:50%;background:#fff;border:2px solid #333;z-index:2}
  .hdr-text h1{font-family:var(--font);font-size:18px;font-weight:800;
    background:linear-gradient(90deg,#fff 40%,var(--a));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
  .hdr-text p{font-size:10px;color:var(--text3);margin-top:1px}
  .hdr-pill{margin-left:auto;font-family:var(--font);font-size:11px;font-weight:700;
    padding:3px 11px;border-radius:20px;background:rgba(255,255,255,.04);border:1px solid var(--brd2);color:var(--text2)}
  .hdr-pill b{color:var(--a)}

  nav{position:relative;z-index:10;display:flex;
    background:rgba(7,7,15,.94);backdrop-filter:blur(20px);border-bottom:1px solid var(--brd)}
  .tab{flex:1;padding:9px 4px;background:none;border:none;cursor:pointer;
    display:flex;flex-direction:column;align-items:center;gap:3px;
    color:var(--text3);font-family:var(--body);font-size:9px;font-weight:600;letter-spacing:.3px;transition:color .2s;position:relative}
  .tab.active{color:var(--a)}
  .tab.active::after{content:'';position:absolute;bottom:0;left:18%;right:18%;height:2px;background:var(--a);border-radius:2px 2px 0 0}

  .page{flex:1;overflow-y:auto;overflow-x:hidden;position:relative;z-index:1;display:none;flex-direction:column;-webkit-overflow-scrolling:touch}
  .page.active{display:flex}
  .page::-webkit-scrollbar{width:3px}
  .page::-webkit-scrollbar-thumb{background:var(--brd2);border-radius:2px}

  /* ── SCANNER ── */
  #pg-scan{padding:14px 14px 100px;gap:12px}

  .vf{position:relative;border-radius:var(--r);overflow:hidden;background:#000;
    border:1px solid var(--brd2);aspect-ratio:3/4;max-height:52vh}
  #cam-vid{width:100%;height:100%;object-fit:cover;display:block}
  #cam-cvs{display:none}
  .vf-ov{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none}
  .cf{width:68%;aspect-ratio:3/4;border:2px solid rgba(245,197,24,.55);border-radius:10px;
    position:relative;box-shadow:0 0 0 9999px rgba(0,0,0,.45);transition:border-color .3s}
  .cf.scanning{border-color:var(--a);animation:cfp .9s ease-in-out infinite alternate}
  .cf.done{border-color:var(--green)}
  @keyframes cfp{
    from{box-shadow:0 0 0 9999px rgba(0,0,0,.45),0 0 0 0 var(--ag)}
    to  {box-shadow:0 0 0 9999px rgba(0,0,0,.45),0 0 18px 4px var(--ag)}}
  .cfc{position:absolute;width:16px;height:16px;border-color:inherit;border-style:solid}
  .cfc.tl{top:-2px;left:-2px;border-width:3px 0 0 3px;border-radius:4px 0 0 0}
  .cfc.tr{top:-2px;right:-2px;border-width:3px 3px 0 0;border-radius:0 4px 0 0}
  .cfc.bl{bottom:-2px;left:-2px;border-width:0 0 3px 3px;border-radius:0 0 0 4px}
  .cfc.br{bottom:-2px;right:-2px;border-width:0 3px 3px 0;border-radius:0 0 4px 0}
  .sl{position:absolute;left:6%;right:6%;height:2px;
    background:linear-gradient(90deg,transparent,var(--a),transparent);
    box-shadow:0 0 8px var(--ag);animation:sm 1.8s ease-in-out infinite;display:none}
  .cf.scanning .sl{display:block}
  @keyframes sm{0%{top:5%}50%{top:92%}100%{top:5%}}
  .vf-ph{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;
    justify-content:center;gap:10px;background:var(--bg2)}
  .vf-ph.hidden{display:none}
  .vf-ph svg{opacity:.18}
  .vf-ph p{font-size:12px;color:var(--text3);text-align:center}

  .btns{display:flex;gap:9px}
  .btn{padding:13px 16px;border:none;border-radius:var(--r2);cursor:pointer;
    font-family:var(--font);font-size:13px;font-weight:700;letter-spacing:.3px;
    display:flex;align-items:center;justify-content:center;gap:7px;transition:all .18s}
  .btn:active{transform:scale(.97)}
  .btn:disabled{opacity:.3;pointer-events:none}
  .btn-start{flex:1;background:rgba(255,59,92,.12);border:1px solid rgba(255,59,92,.3);color:var(--red)}
  .btn-scan {flex:1;background:var(--bg3);border:1px solid var(--a);color:var(--a);box-shadow:0 0 10px var(--ag)}
  .btn-add  {flex:1;background:var(--a);color:#000;box-shadow:0 4px 16px var(--ag)}
  .btn-ghost{flex:1;background:rgba(255,255,255,.05);border:1px solid var(--brd2);color:var(--text2)}
  .btn-xl   {width:100%;padding:15px}

  .rc{background:var(--surf);border:1px solid var(--brd2);border-radius:var(--r);overflow:hidden;display:none}
  .rc.show{display:block;animation:fu .3s ease}
  @keyframes fu{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
  .rc-head{padding:11px 14px;background:rgba(255,255,255,.03);border-bottom:1px solid var(--brd);
    display:flex;align-items:center;gap:8px}
  .rc-lbl{font-family:var(--font);font-size:10px;font-weight:700;letter-spacing:.5px;color:var(--a)}
  .rc-sub{margin-left:auto;font-size:10px;color:var(--text3)}

  .fields{display:flex;flex-direction:column;gap:1px;background:var(--brd)}
  .field{background:var(--surf);padding:10px 14px}
  .field-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
  .fl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--text3);margin-bottom:5px}
  .fi{width:100%;background:var(--bg3);border:1px solid var(--brd);border-radius:8px;
    padding:8px 11px;color:var(--text);font-family:var(--body);font-size:14px;outline:none;transition:border-color .2s}
  .fi:focus{border-color:rgba(245,197,24,.4)}
  .fi-bold{font-family:var(--font);font-weight:700;font-size:16px}
  .fi-code{font-family:var(--font);font-weight:700;letter-spacing:.8px;text-transform:uppercase}

  .tpill{padding:5px 12px;border-radius:20px;font-size:11px;font-weight:700;cursor:pointer;
    border:1.5px solid;transition:opacity .15s;user-select:none}
  .tpill.off{opacity:.3}
  .type-wrap,.fin-wrap{display:flex;flex-wrap:wrap;gap:6px;padding-top:2px}
  .fpill{padding:5px 12px;border-radius:20px;font-size:11px;font-weight:700;cursor:pointer;
    border:1.5px solid var(--brd2);color:var(--text3);background:transparent;transition:all .15s;user-select:none}
  .fpill.on{border-color:var(--a);color:var(--a);background:rgba(245,197,24,.1)}

  .rc-actions{padding:11px 13px;display:flex;gap:8px;border-top:1px solid var(--brd)}

  /* Overlay */
  .ov{position:fixed;inset:0;z-index:200;background:rgba(5,5,12,.93);backdrop-filter:blur(10px);
    display:none;flex-direction:column;align-items:center;justify-content:center;gap:14px;padding:24px}
  .ov.show{display:flex}
  .spinner{width:52px;height:52px;border-radius:50%;border:3px solid rgba(255,255,255,.07);
    border-top-color:var(--a);animation:sp .7s linear infinite}
  @keyframes sp{to{transform:rotate(360deg)}}
  .ov-title{font-family:var(--font);font-size:15px;font-weight:700;color:var(--a);text-align:center}
  .ov-sub{font-size:12px;color:var(--text3);text-align:center;line-height:1.6}
  .ov-progress{width:200px;height:4px;background:var(--bg3);border-radius:2px;overflow:hidden}
  .ov-bar{height:100%;background:var(--a);border-radius:2px;width:0%;transition:width .3s}

  /* ── SAISIE MANUELLE ── */
  #pg-manual{padding:16px 14px 100px;gap:11px}
  .card-form{background:var(--surf);border:1px solid var(--brd2);border-radius:var(--r);overflow:hidden}
  .card-form-head{padding:11px 14px;background:rgba(255,255,255,.03);border-bottom:1px solid var(--brd);display:flex;align-items:center;gap:8px}
  .card-form-lbl{font-family:var(--font);font-size:10px;font-weight:700;letter-spacing:.5px;color:var(--a)}

  /* ── LISTE ── */
  #pg-list{padding:0 0 100px}
  .list-bar{padding:12px 14px;display:flex;align-items:center;gap:10px;
    position:sticky;top:0;z-index:5;background:rgba(7,7,15,.92);backdrop-filter:blur(14px);border-bottom:1px solid var(--brd)}
  .list-count{font-family:var(--font);font-size:13px;font-weight:700;flex:1;color:var(--text2)}
  .list-count b{color:var(--a)}
  .cr{display:flex;align-items:center;gap:11px;padding:10px 14px;border-bottom:1px solid var(--brd)}
  .cr-idx{font-family:var(--font);font-size:11px;font-weight:700;color:var(--text3);width:24px;text-align:right;flex-shrink:0}
  .cr-info{flex:1;min-width:0}
  .cr-name{font-family:var(--font);font-size:14px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .cr-sub{font-size:11px;color:var(--text3);margin-top:2px}
  .cr-tags{display:flex;gap:4px;margin-top:4px;flex-wrap:wrap}
  .tag{font-size:9px;font-weight:700;padding:2px 7px;border-radius:5px}
  .del-btn{width:32px;height:32px;flex-shrink:0;border:none;border-radius:8px;
    background:rgba(255,59,92,.08);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--red)}
  .empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
    gap:12px;padding:40px;text-align:center}
  .empty svg{opacity:.15}
  .empty h3{font-family:var(--font);font-size:16px;color:var(--text2)}
  .empty p{font-size:12px;color:var(--text3);line-height:1.7}
  .export-bar{padding:10px 14px calc(10px + var(--sb));
    background:rgba(7,7,15,.95);backdrop-filter:blur(14px);border-top:1px solid var(--brd);position:sticky;bottom:0}

  .toast{position:fixed;bottom:88px;left:50%;transform:translateX(-50%) translateY(10px);z-index:300;
    background:rgba(18,18,28,.97);backdrop-filter:blur(20px);border:1px solid var(--brd2);
    border-radius:20px;padding:8px 16px;font-size:12px;font-weight:600;white-space:nowrap;
    opacity:0;transition:all .22s;pointer-events:none}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
  .toast.ok  {border-color:rgba(0,230,118,.3);color:var(--green)}
  .toast.err {border-color:rgba(255,59,92,.3);color:var(--red)}
  .toast.info{border-color:rgba(245,197,24,.3);color:var(--a)}
  </style>
</head>
<body>
<div id="app">

  <header>
    <div class="ball"><div class="ball-t"></div><div class="ball-b"></div><div class="ball-c"></div></div>
    <div class="hdr-text"><h1>PokéScan</h1><p>OCR gratuit · Offline · Excel</p></div>
    <div class="hdr-pill"><b id="hdr-n">0</b> carte(s)</div>
  </header>

  <nav>
    <button class="tab active" onclick="goTo('scan',this)">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
      Scanner OCR
    </button>
    <button class="tab" onclick="goTo('manual',this)">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      Manuel
    </button>
    <button class="tab" onclick="goTo('list',this)">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
      Liste & Export
    </button>
  </nav>

  <!-- PAGE SCANNER OCR -->
  <div id="pg-scan" class="page active">
    <div style="padding:14px 14px 100px;gap:12px;display:flex;flex-direction:column">

      <div class="vf">
        <video id="cam-vid" autoplay muted playsinline></video>
        <canvas id="cam-cvs"></canvas>
        <div class="vf-ov">
          <div class="cf" id="cf">
            <span class="cfc tl"></span><span class="cfc tr"></span>
            <span class="cfc bl"></span><span class="cfc br"></span>
            <div class="sl"></div>
          </div>
        </div>
        <div class="vf-ph" id="vf-ph">
          <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
          <p>Appuyez sur Démarrer</p>
        </div>
      </div>

      <div class="btns">
        <button class="btn btn-start" id="btn-cam" onclick="toggleCam()">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
          Démarrer
        </button>
        <button class="btn btn-scan" id="btn-snap" onclick="snap()" disabled>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          Scanner
        </button>
      </div>

      <!-- Résultat OCR -->
      <div class="rc" id="rc">
        <div class="rc-head">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="color:var(--a)"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          <span class="rc-lbl">RÉSULTAT OCR</span>
          <span class="rc-sub">Vérifiez et corrigez si besoin</span>
        </div>
        <div class="fields">
          <div class="field">
            <div class="fl">Nom du Pokémon</div>
            <input class="fi fi-bold" id="f-name" placeholder="Ex: Pikachu"/>
          </div>
          <div class="field">
            <div class="fl">Type(s)</div>
            <div class="type-wrap" id="f-type-wrap"></div>
          </div>
          <div class="field">
            <div class="field-row">
              <div>
                <div class="fl">Code set</div>
                <input class="fi fi-code" id="f-code" placeholder="ASC…"/>
              </div>
              <div>
                <div class="fl">N° / Total</div>
                <input class="fi" style="font-family:var(--font);font-weight:700" id="f-num" placeholder="039/217"/>
              </div>
            </div>
          </div>
          <div class="field">
            <div class="fl">Finition</div>
            <div class="fin-wrap" id="f-fin-wrap"></div>
          </div>
        </div>
        <div class="rc-actions">
          <button class="btn btn-add" onclick="addCard()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Ajouter
          </button>
          <button class="btn btn-ghost" onclick="resetScan()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.53"/></svg>
            Reset
          </button>
        </div>
      </div>

    </div>
  </div>

  <!-- PAGE MANUELLE -->
  <div id="pg-manual" class="page">
    <div style="padding:16px 14px 100px;display:flex;flex-direction:column;gap:11px">
      <div class="card-form">
        <div class="card-form-head">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="color:var(--a)"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          <span class="card-form-lbl">SAISIE MANUELLE</span>
        </div>
        <div class="fields">
          <div class="field">
            <div class="fl">Nom du Pokémon *</div>
            <input class="fi fi-bold" id="m-name" placeholder="Ex: Dracaufeu…"/>
          </div>
          <div class="field">
            <div class="fl">Type(s)</div>
            <div class="type-wrap" id="m-type-wrap"></div>
          </div>
          <div class="field">
            <div class="field-row">
              <div>
                <div class="fl">Code set</div>
                <input class="fi fi-code" id="m-code" placeholder="ASC, MEW…"/>
              </div>
              <div>
                <div class="fl">N° / Total</div>
                <input class="fi" style="font-family:var(--font);font-weight:700" id="m-num" placeholder="039/217"/>
              </div>
            </div>
          </div>
          <div class="field">
            <div class="fl">Finition</div>
            <div class="fin-wrap" id="m-fin-wrap"></div>
          </div>
        </div>
      </div>
      <button class="btn btn-add btn-xl" onclick="addManual()">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Ajouter à la liste
      </button>
    </div>
  </div>

  <!-- PAGE LISTE -->
  <div id="pg-list" class="page">
    <div class="list-bar">
      <div class="list-count"><b id="list-n">0</b> carte(s)</div>
      <button class="btn btn-ghost" style="padding:7px 12px;font-size:11px;flex:none" id="btn-clear" onclick="clearAll()">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/></svg>
        Tout vider
      </button>
    </div>
    <div id="card-list"></div>
    <div id="list-empty" class="empty">
      <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
      <h3>Aucune carte</h3>
      <p>Scannez ou saisissez vos cartes</p>
    </div>
    <div class="export-bar">
      <button class="btn btn-add btn-xl" onclick="exportExcel()" id="btn-export" disabled>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="11" x2="12" y2="17"/><polyline points="9 14 12 17 15 14"/></svg>
        Télécharger Excel
      </button>
    </div>
  </div>

</div>

<!-- Overlay OCR -->
<div class="ov" id="ov">
  <div class="spinner"></div>
  <div class="ov-title" id="ov-title">Lecture OCR en cours…</div>
  <div class="ov-sub" id="ov-sub">Analyse du texte sur la carte</div>
  <div class="ov-progress"><div class="ov-bar" id="ov-bar"></div></div>
</div>

<div class="toast" id="toast"></div>

<!-- Tesseract.js OCR (gratuit, tourne sur le téléphone) -->
<script src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script>
<!-- SheetJS pour Excel -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<script>
const STORE = 'pokescan_v4';

const TYPES = {
  'Feu':'#ff6b35','Eau':'#4fc3f7','Plante':'#81c784','Électrik':'#ffd54f',
  'Psy':'#ce93d8','Combat':'#ff8a65','Obscur':'#7b8a9a','Acier':'#90a4ae',
  'Normal':'#bdbdbd','Glace':'#b3e5fc','Poison':'#ab47bc','Dragon':'#7986cb',
  'Fée':'#f48fb1','Incolore':'#e0e0e0'
};
const FINITIONS = ['Standard','Reverse Holo','Holo','Full Art','AR','SAR','UR','SIR','IR'];

// Correspondances types anglais → français (sur les cartes)
const TYPE_MAP = {
  'fire':'Feu','water':'Eau','grass':'Plante','lightning':'Électrik','electric':'Électrik',
  'psychic':'Psy','fighting':'Combat','darkness':'Obscur','dark':'Obscur','metal':'Acier',
  'steel':'Acier','colorless':'Incolore','dragon':'Dragon','fairy':'Fée','ice':'Glace',
  'poison':'Poison','normal':'Normal'
};

// Codes sets connus
const SET_CODES = [
  'ASC','MEW','MEG','PFL','SVI','OBF','PAR','PAF','TEF','TWM','SCR',
  'SSH','CRE','EVS','FST','BRS','AST','LOR','SIT','SIT','CRZ',
  'SWH','CEL','VIV','CPA','DAA','RCH','UNB','UNM','DET','TM','LOT',
  'FLI','CES','DRM','BUS','GRI','SM','STS','EVO','FCO','BKP','BKT',
  'XY','PHF','FFI','FLF','PLF','PLB','BCR','DRX','NXD','EPO','NVI',
  'HS','UL','UD','TM','AR','SH','PT','RR','SF','LA','MD','GE','MT',
  'DP','PK','DS','HP','LM','DX','EM','UF','HL','RG','SS','MA','EX',
  'AQ','NEO','GYM','PROMO'
];

let cards=[], camStream=null, ocrWorker=null;

function load(){ try{cards=JSON.parse(localStorage.getItem(STORE)||'[]')}catch{cards=[]} }
function save(){ localStorage.setItem(STORE,JSON.stringify(cards)) }
function gid(){ return Date.now().toString(36)+Math.random().toString(36).slice(2,5) }
function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/"/g,'&quot;') }

// ── NAV ──────────────────────────────────
function goTo(id,btn){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('active'));
  document.getElementById('pg-'+id).classList.add('active');
  btn.classList.add('active');
  if(id==='list') renderList();
}

// ── WIDGETS (types + finitions) ───────────
function makeTypeWrap(containerId, selected=[]){
  document.getElementById(containerId).innerHTML = Object.keys(TYPES).map(t=>{
    const on = selected.includes(t);
    return `<div class="tpill ${on?'on':'off'}" data-type="${t}"
      style="color:${TYPES[t]};border-color:${TYPES[t]};background:${on?TYPES[t]+'28':'transparent'}"
      onclick="toggleType(this,'${t}','${containerId}')">${t}</div>`;
  }).join('');
}

function makeFinWrap(containerId, selected='Standard'){
  document.getElementById(containerId).innerHTML = FINITIONS.map(f=>
    `<div class="fpill ${f===selected?'on':''}" data-fin="${f}"
      onclick="selectFin(this,'${containerId}')">${f}</div>`
  ).join('');
}

function toggleType(el,t,cid){
  const on=el.classList.toggle('on');
  el.classList.toggle('off',!on);
  el.style.background=on?TYPES[t]+'28':'transparent';
}
function selectFin(el,cid){
  document.querySelectorAll(`#${cid} .fpill`).forEach(e=>e.classList.remove('on'));
  el.classList.add('on');
}

// ── CAMERA ───────────────────────────────
async function toggleCam(){
  if(camStream){stopCam();return;}
  try{
    camStream=await navigator.mediaDevices.getUserMedia({
      video:{facingMode:'environment',width:{ideal:1920},height:{ideal:1080}}
    });
    document.getElementById('cam-vid').srcObject=camStream;
    document.getElementById('vf-ph').classList.add('hidden');
    const b=document.getElementById('btn-cam');
    b.innerHTML=`<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/></svg> Arrêter`;
    b.className='btn btn-ghost';
    document.getElementById('btn-snap').disabled=false;
  }catch{ toast('❌ Accès caméra refusé','err') }
}

function stopCam(){
  if(camStream){camStream.getTracks().forEach(t=>t.stop());camStream=null;}
  document.getElementById('cam-vid').srcObject=null;
  document.getElementById('vf-ph').classList.remove('hidden');
  const b=document.getElementById('btn-cam');
  b.innerHTML=`<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> Démarrer`;
  b.className='btn btn-start';
  document.getElementById('btn-snap').disabled=true;
}

// ── SNAP & OCR ───────────────────────────
async function snap(){
  if(!camStream){toast('⚠️ Démarrez la caméra','err');return;}
  const vid=document.getElementById('cam-vid');
  const cvs=document.getElementById('cam-cvs');
  cvs.width=vid.videoWidth||1280; cvs.height=vid.videoHeight||720;
  cvs.getContext('2d').drawImage(vid,0,0);

  document.getElementById('cf').classList.add('scanning');
  showOv('Initialisation OCR…','Chargement du moteur de reconnaissance…',5);
  stopCam();

  try{
    const text = await runOCR(cvs);
    showOv('Analyse du texte…','Extraction des informations de la carte…',90);
    const parsed = parseCardText(text);
    document.getElementById('ov').classList.remove('show');
    document.getElementById('cf').classList.remove('scanning');
    document.getElementById('cf').classList.add('done');
    renderResult(parsed);
  }catch(e){
    document.getElementById('ov').classList.remove('show');
    document.getElementById('cf').classList.remove('scanning');
    toast('❌ OCR échoué — '+(e.message||'erreur'),'err');
  }
}

function showOv(title, sub, pct){
  document.getElementById('ov').classList.add('show');
  document.getElementById('ov-title').textContent=title;
  document.getElementById('ov-sub').textContent=sub;
  document.getElementById('ov-bar').style.width=pct+'%';
}

async function runOCR(canvas){
  if(!ocrWorker){
    showOv('Chargement OCR…','Première utilisation : téléchargement du moteur (~10s)',15);
    ocrWorker = await Tesseract.createWorker('eng+fra', 1, {
      logger: m => {
        if(m.status==='loading tesseract core') showOv('Chargement OCR…','Moteur Tesseract…',20);
        if(m.status==='initializing tesseract') showOv('Initialisation…','Préparation du moteur…',40);
        if(m.status==='loading language traineddata') showOv('Chargement langue…','Modèle anglais + français…',60);
        if(m.status==='recognizing text') {
          const p=Math.round((m.progress||0)*30)+65;
          showOv('Lecture du texte…','Reconnaissance en cours…',p);
        }
      }
    });
  }
  const { data: { text } } = await ocrWorker.recognize(canvas);
  return text;
}

// ── PARSE OCR TEXT ───────────────────────
function parseCardText(raw){
  const text = raw;
  const lines = text.split('\n').map(l=>l.trim()).filter(l=>l.length>1);
  const upper = text.toUpperCase();

  // Nom : première ligne significative (souvent la plus grande sur la carte)
  // On prend la ligne la plus longue parmi les 5 premières, > 3 chars, pas un chiffre
  let name = '';
  const candidates = lines.slice(0,8).filter(l=>l.length>3 && !/^\d/.test(l) && !/^(HP|PV|\d+\/\d+)$/i.test(l));
  if(candidates.length) name = candidates[0].replace(/[^a-zA-ZÀ-ÿ\s\-'é]/g,'').trim();

  // Numéro : format XXX/YYY
  const numMatch = text.match(/\b(\d{1,3})\s*\/\s*(\d{2,3})\b/);
  const number = numMatch ? `${numMatch[1].padStart(3,'0')}/${numMatch[2]}` : '';

  // Code set : cherche parmi les codes connus
  let set_code = '';
  for(const code of SET_CODES){
    const re = new RegExp(`\\b${code}\\b`,'i');
    if(re.test(upper)){ set_code=code; break; }
  }
  // Fallback : cherche un pattern 2-4 lettres majuscules isolé
  if(!set_code){
    const scMatch = upper.match(/\b([A-Z]{2,4})\b/g);
    if(scMatch){
      // Filtre les mots courants non-codes
      const ignore=['HP','PV','AND','THE','FOR','WITH','TYPE','ITEM','YOU','CAN','USE','ALL'];
      const filtered = scMatch.filter(m=>!ignore.includes(m));
      if(filtered.length) set_code = filtered[filtered.length-1]; // souvent en bas de carte
    }
  }

  // Type : cherche les noms de types dans le texte
  const types=[];
  for(const [en,fr] of Object.entries(TYPE_MAP)){
    if(upper.includes(en.toUpperCase()) && !types.includes(fr)) types.push(fr);
  }

  // Finition : indices visuels dans le texte (limité sans vision)
  // On détecte "FULL ART", "ILLUSTRATION RARE", etc. si présents dans le texte imprimé
  let finish = 'Standard';
  if(/FULL.?ART/i.test(text)) finish='Full Art';
  else if(/ILLUSTRATION.?RARE/i.test(text)||/\bIR\b/.test(upper)) finish='IR';
  else if(/SPECIAL.?ART/i.test(text)||/\bSAR\b/.test(upper)) finish='SAR';
  else if(/\bAR\b/.test(upper)) finish='AR';
  else if(/ULTRA.?RARE/i.test(text)||/\bUR\b/.test(upper)) finish='UR';
  else if(/HOLO/i.test(text)) finish='Holo';

  return {name, types, set_code, number, finish};
}

// ── RENDER RESULT ─────────────────────────
function renderResult(c){
  document.getElementById('f-name').value = c.name||'';
  document.getElementById('f-code').value = c.set_code||'';
  document.getElementById('f-num').value  = c.number||'';
  makeTypeWrap('f-type-wrap', c.types||[]);
  makeFinWrap('f-fin-wrap', c.finish||'Standard');
  document.getElementById('rc').classList.add('show');
  document.getElementById('rc').scrollIntoView({behavior:'smooth',block:'nearest'});
}

// ── ADD (depuis scanner) ──────────────────
function addCard(){
  const name=document.getElementById('f-name').value.trim();
  if(!name){toast('⚠️ Le nom est requis','err');return;}
  const types=[...document.querySelectorAll('#f-type-wrap .tpill.on')].map(e=>e.dataset.type);
  const finish=document.querySelector('#f-fin-wrap .fpill.on')?.dataset.fin||'Standard';
  cards.push({
    id:gid(), name, types,
    set_code: document.getElementById('f-code').value.trim().toUpperCase()||'',
    number:   document.getElementById('f-num').value.trim()||'',
    finish, addedAt: new Date().toISOString()
  });
  save(); updateCount();
  toast(`✅ ${name} ajouté !`,'ok');
  resetScan();
}

function resetScan(){
  document.getElementById('rc').classList.remove('show');
  document.getElementById('cf').classList.remove('scanning','done');
}

// ── ADD MANUEL ───────────────────────────
function addManual(){
  const name=document.getElementById('m-name').value.trim();
  if(!name){toast('⚠️ Le nom est requis','err');return;}
  const types=[...document.querySelectorAll('#m-type-wrap .tpill.on')].map(e=>e.dataset.type);
  const finish=document.querySelector('#m-fin-wrap .fpill.on')?.dataset.fin||'Standard';
  cards.push({
    id:gid(), name, types,
    set_code: document.getElementById('m-code').value.trim().toUpperCase()||'',
    number:   document.getElementById('m-num').value.trim()||'',
    finish, addedAt: new Date().toISOString()
  });
  save(); updateCount();
  toast(`✅ ${name} ajouté !`,'ok');
  // reset
  ['m-name','m-code','m-num'].forEach(id=>document.getElementById(id).value='');
  makeTypeWrap('m-type-wrap',[]);
  makeFinWrap('m-fin-wrap','Standard');
}

// ── LISTE ────────────────────────────────
function renderList(){
  const el=document.getElementById('card-list');
  const emp=document.getElementById('list-empty');
  document.getElementById('list-n').textContent=cards.length;
  document.getElementById('btn-export').disabled=!cards.length;
  document.getElementById('btn-clear').style.visibility=cards.length?'visible':'hidden';
  if(!cards.length){el.innerHTML='';emp.style.display='flex';return;}
  emp.style.display='none';
  el.innerHTML=cards.map((c,i)=>`
    <div class="cr">
      <div class="cr-idx">${i+1}</div>
      <div class="cr-info">
        <div class="cr-name">${esc(c.name)}</div>
        <div class="cr-sub">${c.set_code||'—'} · ${c.number||'—'}</div>
        <div class="cr-tags">
          ${c.types.map(t=>`<span class="tag" style="background:${TYPES[t]||'#636366'}22;color:${TYPES[t]||'#636366'}">${t}</span>`).join('')}
          <span class="tag" style="background:rgba(245,197,24,.1);color:var(--a)">${c.finish}</span>
        </div>
      </div>
      <button class="del-btn" onclick="delCard('${c.id}')">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
      </button>
    </div>`).join('');
}

function delCard(id){ cards=cards.filter(c=>c.id!==id);save();updateCount();renderList();toast('🗑️ Supprimé','info') }
function clearAll(){ if(!confirm('Vider toute la liste ?'))return;cards=[];save();updateCount();renderList();toast('🗑️ Vidé','info') }
function updateCount(){ document.getElementById('hdr-n').textContent=cards.length }

// ── EXPORT EXCEL ─────────────────────────
function exportExcel(){
  if(!cards.length){toast('Aucune carte','err');return;}
  const rows=cards.map((c,i)=>({
    '#': i+1,
    'Nom': c.name,
    'Type(s)': c.types.join(', '),
    'Code Set': c.set_code,
    'N° / Total': c.number,
    'Finition': c.finish,
    'Date scan': new Date(c.addedAt).toLocaleDateString('fr-FR')
  }));
  const ws=XLSX.utils.json_to_sheet(rows);
  ws['!cols']=[{wch:4},{wch:24},{wch:20},{wch:10},{wch:10},{wch:14},{wch:12}];
  const wb=XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb,ws,'Collection Pokémon');
  XLSX.writeFile(wb,`collection_pokemon_${new Date().toLocaleDateString('fr-FR').replace(/\//g,'-')}.xlsx`);
  toast('✅ Excel téléchargé !','ok');
}

// ── TOAST ────────────────────────────────
let _t;
function toast(msg,type='info'){
  const el=document.getElementById('toast');
  el.textContent=msg;el.className=`toast ${type} show`;
  clearTimeout(_t);_t=setTimeout(()=>el.classList.remove('show'),2800);
}

// ── INIT ─────────────────────────────────
load(); updateCount();
makeTypeWrap('f-type-wrap',[]);
makeFinWrap('f-fin-wrap','Standard');
makeTypeWrap('m-type-wrap',[]);
makeFinWrap('m-fin-wrap','Standard');
if('serviceWorker' in navigator) navigator.serviceWorker.register('sw.js').catch(()=>{});
</script>
</body>
</html>
